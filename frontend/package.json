{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm check && tsc -b && vite build",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --error-on-warnings"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@navikt/aksel-icons": "8.11.1",
    "@navikt/ds-css": "8.11.1",
    "@navikt/ds-react": "8.11.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "date-fns": "4.4.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.77.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.0.5"
}
